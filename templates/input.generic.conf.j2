{% set _config = telegraf_inputs_disk_options | combine(item.value) if item.key == 'disk' else item.value %}
[[inputs.{{ _config["_input_name"] | default(item.key) }}]]
{% for conf,val in _config.items() %}
{%   if conf != "_input_name" %}
{%     if val is string %}
  {{ conf }} = {{ val }}
{%     elif val is sequence %}
  {{ conf }} = [ "{{ val | sort | join('","') }}" ]
{%     else %}
  {{ conf }} = {{ val }}
{%     endif %}
{%   endif %}
{% endfor %}

